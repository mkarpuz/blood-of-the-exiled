{
  "name": "@boe/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@boe/contracts": "workspace:*",
    "@boe/game-data": "workspace:*",
    "@dimforge/rapier3d-compat": "^0.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.178.1",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  }
}
