{
  "name": "blood-of-the-exiled",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -k -n server,web -c red,cyan \"pnpm --filter @boe/server dev\" \"pnpm --filter @boe/web dev\"",
    "dev:web": "pnpm --filter @boe/web dev",
    "dev:server": "pnpm --filter @boe/server dev",
    "test": "pnpm -r test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "assets:hash": "node --import tsx tools/assets/hash-sources.ts",
    "assets:export": "bash tools/assets/export-runtime.sh",
    "assets:validate": "node --import tsx tools/assets/validate-runtime.ts",
    "check": "pnpm typecheck && pnpm test:unit && pnpm build && pnpm assets:validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@gltf-transform/cli": "^4.2.1",
    "@gltf-transform/core": "^4.2.1",
    "@gltf-transform/extensions": "^4.2.1",
    "@gltf-transform/functions": "^4.2.1",
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.0.15",
    "concurrently": "^9.2.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
